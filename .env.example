# === GitHub ===
# Personal Access Token (fine-grained) con permisos de lectura
# en Contents, Issues, Metadata para los repos a monitorear.
# Generar en: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=github_pat_REPLACE_WITH_YOUR_TOKEN

# === Google Drive ===
# Ruta al JSON de la Service Account (relativa al root del proyecto)
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# ID de la carpeta de Drive donde vive config.json y donde se sube el reporte.
# Obtenerlo de la URL: drive.google.com/drive/folders/<ESTE_ES_EL_ID>
GOOGLE_DRIVE_FOLDER_ID=REPLACE_WITH_FOLDER_ID

# Nombre del archivo de configuración dentro de la carpeta de Drive
DRIVE_CONFIG_FILENAME=config.json

# === PostgreSQL ===
# Cuando corres con docker-compose, el host es el nombre del servicio "postgres".
# Si ejecutas scripts localmente contra la BD dockerizada, cambia a "localhost".
DB_HOST=postgres
DB_PORT=5432
DB_NAME=github_data
DB_USER=pipeline
DB_PASSWORD=changeme_in_real_env